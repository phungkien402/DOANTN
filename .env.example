# DOANTN — thesis project, port 8001
# Shares vLLM (localhost:8000) with EHC_HELPDESK

# Redmine
REDMINE_URL=http://co.ehc.vn:81/redmine
REDMINE_API_KEY=your_api_key_here
REDMINE_PROJECT=ehcfaq

# vLLM
VLLM_BASE_URL=http://localhost:8000
VLLM_MODEL=Qwen/Qwen2.5-7B-Instruct

# Embedding (local HuggingFace model id or path)
EMBED_MODEL=BAAI/bge-m3
RERANKER_MODEL=BAAI/bge-reranker-v2-m3

# Qdrant
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=doantn_faq

# RAG settings
RETRIEVER_TOP_K=10
RERANKER_TOP_N=3
CONFIDENCE_THRESHOLD=0.4

# Session
SESSION_MAX_TURNS=10

# Slack
SLACK_BOT_TOKEN=xoxb-your-token-here
SLACK_SIGNING_SECRET=your-signing-secret-here
SLACK_ADMIN_USERS=U12345,U67890

# Admin
ADMIN_TOKEN=your-admin-token-here
MAINTENANCE_MODE=false

# Langfuse (Phase C — observability)
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_SECRET_KEY=sk-lf-...
LANGFUSE_HOST=http://localhost:3000

# Telegram
TELEGRAM_BOT_TOKEN=your-telegram-bot-token-here

# Zalo OA
ZALO_OA_SECRET=your-zalo-oa-secret-here
ZALO_ACCESS_TOKEN=your-zalo-access-token-here

# Redis (Phase D — async queue)
REDIS_URL=redis://localhost:6379
